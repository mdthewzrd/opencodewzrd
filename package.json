{
  "name": "@wzrddev/opencode-remi",
  "version": "0.1.0",
  "description": "WZRD.dev agent for OpenCode - Auto-mode AI assistant with 5 modes and 180+ skills",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "wzrd": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:clean && npm run build:core && npm run build:skills",
    "build:clean": "rm -rf dist",
    "build:core": "tsc && chmod +x dist/cli.js",
    "build:skills": "node scripts/bundle-skills.js",
    "prepack": "npm run build",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "opencode",
    "wzrd",
    "ai",
    "assistant",
    "agent",
    "developer",
    "tool",
    "skills"
  ],
  "author": "WZRD.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wzrddev/opencodewzrd.git"
  },
  "bugs": {
    "url": "https://github.com/wzrddev/opencodewzrd/issues"
  },
  "homepage": "https://github.com/wzrddev/opencodewzrd#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.3.4",
    "inquirer": "^8.2.7"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "opencode": {
    "type": "agent",
    "name": "Remi",
    "description": "WZRD.dev agent with auto-mode detection",
    "icon": "🤖",
    "version": "0.1.0",
    "compatibility": {
      "opencode": ">=1.0.0"
    },
    "permissions": [
      "filesystem",
      "network",
      "process"
    ]
  }
}
