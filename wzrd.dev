#!/usr/bin/env node

const { spawn, execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

console.log('╔══════════════════════════════════════════════════════════╗');
console.log('║           WZRD.dev - Launching OpenCode                  ║');
console.log('║              with Remi AI Agent                          ║');
console.log('╚══════════════════════════════════════════════════════════╝\n');

try {
  execSync('which opencode', { stdio: 'ignore' });
  
  console.log('✅ OpenCode found');
  console.log('🚀 Launching OpenCode TUI in current directory...\n');
  
  // Launch opencode in current directory
  const opencode = spawn('opencode', [process.cwd()], {
    stdio: 'inherit',
    env: {
      ...process.env,
      WZRD_AGENT: 'remi'
    }
  });
  
  opencode.on('error', (err) => {
    console.error('❌ Failed to launch OpenCode:', err.message);
    process.exit(1);
  });
  
  opencode.on('exit', (code) => {
    process.exit(code);
  });
  
} catch (error) {
  console.error('❌ OpenCode not found.');
  console.log('\n📦 Install: brew install opencode or npm install -g @opencode/cli\n');
  
  const cliPath = path.join(__dirname, 'dist', 'cli.js');
  if (fs.existsSync(cliPath)) {
    spawn('node', [cliPath], { stdio: 'inherit' });
  }
  process.exit(1);
}
