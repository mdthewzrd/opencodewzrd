#!/usr/bin/env node

/**
 * WZRD.dev - AI Development Assistant
 * Direct launch with Remi AI
 */

const { spawn } = require('child_process');
const path = require('path');
const fs = require('fs');

console.log('╔══════════════════════════════════════════════════════════╗');
console.log('║              WZRD.dev - AI Development Assistant          ║');
console.log('║              Powered by Remi AI Agent                     ║');
console.log('╚══════════════════════════════════════════════════════════╝\n');

// Check for wzrd-redesign TUI
const homeDir = process.env.HOME || process.env.USERPROFILE || '';
const possibleTUIPaths = [
  path.join(homeDir, 'wzrd-redesign', 'bin', 'wzrd-dev-optimized'),
  path.join(homeDir, 'wzrd-dev', 'bin', 'wzrd-dev-optimized'),
  path.join('/home', 'mdwzrd', 'wzrd-redesign', 'bin', 'wzrd-dev-optimized'),
];

const tuiPath = possibleTUIPaths.find(p => fs.existsSync(p));

if (tuiPath) {
  console.log('🚀 Launching WZRD.dev TUI...\n');
  const tui = spawn('node', [tuiPath, '--mode', 'chat'], {
    stdio: 'inherit',
    env: { ...process.env, WZRD_AGENT: 'remi' }
  });
  
  tui.on('error', () => runBuiltInCLI());
  tui.on('exit', (code) => process.exit(code));
} else {
  console.log('💡 WZRD.dev CLI Mode\n');
  console.log('   Tip: Install wzrd-redesign for full TUI experience');
  console.log('   GitHub: https://github.com/mdthewzrd/wzrd-redesign\n');
  runBuiltInCLI();
}

function runBuiltInCLI() {
  const cliPath = path.join(__dirname, 'dist', 'cli.js');
  
  if (!fs.existsSync(cliPath)) {
    console.error('❌ CLI not found. Reinstall: npm install -g opencode-wzrd');
    process.exit(1);
  }
  
  const cli = spawn('node', [cliPath], {
    stdio: 'inherit',
    env: { ...process.env, WZRD_MODE: 'cli' }
  });
  
  cli.on('error', (err) => {
    console.error('❌ Error:', err.message);
    process.exit(1);
  });
}
