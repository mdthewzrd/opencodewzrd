#!/usr/bin/env node

/**
 * WZRD.dev - Launch OpenCode with Remi AI
 * Launches OpenCode TUI with opencode-wzrd extension and Remi agent
 */

const { spawn } = require('child_process');
const path = require('path');

console.log('╔══════════════════════════════════════════════════════════╗');
console.log('║           WZRD.dev - Launching OpenCode                  ║');
console.log('║              with Remi AI Agent                          ║');
console.log('╚══════════════════════════════════════════════════════════╝\n');

// Check if opencode is installed
const { execSync } = require('child_process');
const fs = require('fs');

try {
  // Try to find opencode
  execSync('which opencode', { stdio: 'ignore' });
  
  console.log('✅ OpenCode found');
  console.log('🚀 Launching OpenCode with WZRD.dev extension...\n');
  
  // Launch opencode tui with extension
  const opencode = spawn('opencode', ['tui', '--extension', 'opencode-wzrd'], {
    stdio: 'inherit',
    env: {
      ...process.env,
      WZRD_AGENT: 'remi',
      OPENCODE_EXTENSION: 'opencode-wzrd'
    }
  });
  
  opencode.on('error', (err) => {
    console.error('❌ Failed to launch OpenCode:', err.message);
    console.log('\n💡 OpenCode might not be installed.');
    console.log('   Install from: https://opencode.dev\n');
    process.exit(1);
  });
  
  opencode.on('exit', (code) => {
    process.exit(code);
  });
  
} catch (error) {
  console.error('❌ OpenCode not found on your system.');
  console.log('\n📦 Install OpenCode first:');
  console.log('   macOS:  brew install opencode');
  console.log('   Linux:  curl -fsSL https://opencode.dev/install.sh | bash');
  console.log('   NPM:    npm install -g @opencode/cli');
  console.log('\n💡 Or use the standalone WZRD CLI:\n');
  
  // Fallback to standalone CLI
  const cliPath = path.join(__dirname, 'dist', 'cli.js');
  if (fs.existsSync(cliPath)) {
    spawn('node', [cliPath], { stdio: 'inherit' });
  }
  process.exit(1);
}
