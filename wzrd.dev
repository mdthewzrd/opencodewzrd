#!/usr/bin/env node

/**
 * WZRD.dev - Launch OpenCode with Remi AI
 * Launches OpenCode TUI with WZRD extension
 */

const { spawn, execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

console.log('╔══════════════════════════════════════════════════════════╗');
console.log('║           WZRD.dev - Launching OpenCode                  ║');
console.log('║              with Remi AI Agent                          ║');
console.log('╚══════════════════════════════════════════════════════════╝\n');

// Check if opencode is installed
try {
  execSync('which opencode', { stdio: 'ignore' });
  
  console.log('✅ OpenCode found');
  console.log('🚀 Launching OpenCode TUI...\n');
  console.log('💡 Your WZRD.dev extension (opencode-wzrd) should load automatically.');
  console.log('   If not, install it in OpenCode with: opencode agent add opencode-wzrd\n');
  
  // Launch opencode tui
  const opencode = spawn('opencode', ['tui'], {
    stdio: 'inherit',
    env: {
      ...process.env,
      WZRD_AGENT: 'remi'
    }
  });
  
  opencode.on('error', (err) => {
    console.error('❌ Failed to launch OpenCode:', err.message);
    process.exit(1);
  });
  
  opencode.on('exit', (code) => {
    process.exit(code);
  });
  
} catch (error) {
  console.error('❌ OpenCode not found on your system.');
  console.log('\n📦 Install OpenCode:');
  console.log('   macOS:  brew install opencode');
  console.log('   NPM:    npm install -g @opencode/cli');
  console.log('   Web:    https://opencode.dev\n');
  
  // Fallback to standalone CLI
  console.log('💡 Using standalone WZRD CLI instead...\n');
  const cliPath = path.join(__dirname, 'dist', 'cli.js');
  if (fs.existsSync(cliPath)) {
    spawn('node', [cliPath], { stdio: 'inherit' });
  }
  process.exit(1);
}
