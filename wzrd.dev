#!/usr/bin/env node

/**
 * WZRD.dev Launch Command
 * Automatically launches WZRD.dev TUI with Remi AI
 */

const { spawn } = require('child_process');
const path = require('path');
const fs = require('fs');

// Search for wzrd-redesign TUI
const possiblePaths = [
  path.join(process.env.HOME || process.env.USERPROFILE || '', 'wzrd-redesign', 'bin', 'wzrd-dev-optimized'),
  path.join(process.cwd(), 'wzrd-redesign', 'bin', 'wzrd-dev-optimized'),
  path.join(__dirname, '..', 'wzrd-redesign', 'bin', 'wzrd-dev-optimized'),
  '/home/mdwzrd/wzrd-redesign/bin/wzrd-dev-optimized'
];

console.log('╔══════════════════════════════════════════════════════════╗');
console.log('║              WZRD.dev - AI Development Assistant          ║');
console.log('║            Launching with Remi AI Agent                   ║');
console.log('╚══════════════════════════════════════════════════════════╝\n');

// Find wzrd-redesign
let wzrdRedesignPath = possiblePaths.find(p => fs.existsSync(p));

if (wzrdRedesignPath) {
  console.log('🔍 Found WZRD.dev installation');
  console.log('🚀 Launching WZRD.dev TUI with Remi AI...\n');
  
  const tui = spawn('node', [wzrdRedesignPath, '--mode', 'chat'], {
    stdio: 'inherit',
    env: { 
      ...process.env, 
      WZRD_MODE: 'tui',
      WZRD_AGENT: 'remi'
    }
  });
  
  tui.on('error', (err) => {
    console.error('❌ Failed to launch TUI:', err.message);
    console.log('\n💡 Falling back to basic CLI...');
    runBasicCLI();
  });
  
  tui.on('exit', (code) => {
    process.exit(code);
  });
} else {
  console.log('⚠️  WZRD.dev TUI not found locally');
  console.log('📦 Running basic CLI mode...\n');
  runBasicCLI();
}

function runBasicCLI() {
  const cliPath = path.join(__dirname, 'dist', 'cli.js');
  
  if (!fs.existsSync(cliPath)) {
    console.error('❌ CLI not found. Please reinstall: npm install -g opencode-wzrd');
    process.exit(1);
  }
  
  const cli = spawn('node', [cliPath], {
    stdio: 'inherit',
    env: { ...process.env, WZRD_MODE: 'terminal' }
  });
  
  cli.on('error', (err) => {
    console.error('❌ CLI error:', err.message);
    process.exit(1);
  });
}
