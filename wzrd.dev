#!/usr/bin/env node

/**
 * WZRD.dev - AI Development Assistant
 * Auto-installs and launches full WZRD.dev experience
 */

const { spawn, execSync } = require('child_process');
const path = require('path');
const fs = require('fs');
const os = require('os');

const homeDir = os.homedir();
const wzrdDir = path.join(homeDir, 'wzrd-redesign');
// Try different entry points in order of preference
const possibleBinaries = [
  path.join(wzrdDir, 'bin', 'wzrd-dev-optimized'),  // Full TUI (if works)
  path.join(wzrdDir, 'bin', 'wzrd-redesign'),       // Alternative TUI
  path.join(wzrdDir, 'bin', 'wzrd-cli')             // Basic CLI (fallback)
];

console.log('╔══════════════════════════════════════════════════════════╗');
console.log('║              WZRD.dev - AI Development Assistant          ║');
console.log('║              Powered by Remi AI Agent                     ║');
console.log('╚══════════════════════════════════════════════════════════╝\n');

// Check if wzrd-redesign is installed
if (!fs.existsSync(wzrdDir)) {
  console.log('📦 WZRD.dev framework not found. Installing...');
  console.log('	This is a one-time setup...\n');
  
  try {
    // Clone wzrd-redesign
    console.log('🔄 Cloning WZRD.dev framework...');
    execSync(`git clone https://github.com/mdthewzrd/wzrd-redesign.git "${wzrdDir}"`, { 
      stdio: 'inherit',
      cwd: homeDir
    });
    
    // Install dependencies
    console.log('\n📦 Installing dependencies...');
    execSync('npm install', { 
      stdio: 'inherit',
      cwd: wzrdDir
    });
    
    console.log('\n✅ WZRD.dev framework installed!\n');
    
  } catch (error) {
    console.error('❌ Failed to install WZRD.dev framework');
    console.error('	 Error:', error.message);
    console.log('\n💡 You can still use the basic CLI mode:\n');
    runBasicCLI();
    return;
  }
}

// Find a working binary
const workingBinary = possibleBinaries.find(bin => fs.existsSync(bin));

if (!workingBinary) {
  console.error('❌ No working WZRD.dev entry point found');
  runBasicCLI();
  return;
}

console.log('🚀 Launching WZRD.dev TUI with Remi AI...\n');

const tui = spawn('node', [workingBinary, '--mode', 'chat'], {
  stdio: 'inherit',
  env: { 
    ...process.env,
    WZRD_HOME: wzrdDir,
    WZRD_AGENT: 'remi',
    WZRD_MODE: 'tui'
  }
});
    
    // Install dependencies
    console.log('\n📦 Installing dependencies...');
    execSync('npm install', { 
      stdio: 'inherit',
      cwd: wzrdDir
    });
    
    console.log('\n✅ WZRD.dev framework installed!\n');
    console.log('🚀 Launching WZRD.dev TUI with Remi AI...\n');
    
  } catch (error) {
    console.error('❌ Failed to install WZRD.dev framework');
    console.error('   Error:', error.message);
    console.log('\n💡 You can still use the basic CLI mode:\n');
    runBasicCLI();
    return;
  }
}

// Launch WZRD.dev TUI
console.log('🚀 Launching WZRD.dev TUI with Remi AI...\n');

const tui = spawn('node', [wzrdBinary, '--mode', 'chat'], {
  stdio: 'inherit',
  env: { 
    ...process.env,
    WZRD_HOME: wzrdDir,
    WZRD_AGENT: 'remi',
    WZRD_MODE: 'tui'
  }
});

tui.on('error', (err) => {
  console.error('❌ Failed to launch TUI:', err.message);
  console.log('\n💡 Falling back to basic CLI...');
  runBasicCLI();
});

tui.on('exit', (code) => {
  process.exit(code);
});

function runBasicCLI() {
  const cliPath = path.join(__dirname, 'dist', 'cli.js');
  
  if (!fs.existsSync(cliPath)) {
    console.error('❌ CLI not found. Reinstall: npm install -g opencode-wzrd');
    process.exit(1);
  }
  
  const cli = spawn('node', [cliPath], {
    stdio: 'inherit',
    env: { ...process.env, WZRD_MODE: 'cli' }
  });
  
  cli.on('error', (err) => {
    console.error('❌ Error:', err.message);
    process.exit(1);
  });
}
