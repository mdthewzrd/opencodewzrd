#!/usr/bin/env bash
# WZRD.dev OpenCode Launcher
# Launch command for wzrd.dev -> OpenCode integration

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_header() {
    echo -e "${BLUE}"
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║                WZRD.dev OpenCode Launcher                ║"
    echo "║         Launching AI-powered development assistant        ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

show_help() {
    echo "Usage: wzrd [OPTIONS] [COMMAND]"
    echo ""
    echo "Options:"
    echo "  --launch-opencode    Launch OpenCode with WZRD extension"
    echo "  --terminal           Use terminal mode (default)"
    echo "  --install            Install OpenCode + extension"
    echo "  --version            Show version"
    echo "  --help               Show this help"
    echo ""
    echo "Commands:"
    echo "  chat <message>       Start chat session"
    echo "  modes                List available AI modes"
    echo "  skills               Show loaded skills"
    echo "  setup                Setup configuration"
    echo ""
    echo "Examples:"
    echo "  wzrd --launch-opencode    # Launch OpenCode with extension"
    echo "  wzrd chat \"Hello Remi\"     # Terminal chat mode"
    echo "  wzrd --install            # Install OpenCode + extension"
}

# Check if OpenCode is available
check_opencode() {
    if command -v opencode &> /dev/null; then
        return 0
    elif [ -x "/Applications/OpenCode.app/Contents/MacOS/OpenCode" ]; then
        return 0
    elif [ -x "$HOME/Applications/OpenCode.app/Contents/MacOS/OpenCode" ]; then
        return 0
    else
        return 1
    fi
}

# Launch OpenCode with extension
launch_opencode() {
    if check_opencode; then
        echo -e "${GREEN}🚀 Launching OpenCode with WZRD.dev extension...${NC}"
        
        # Check if extension is installed
        if opencode --list-extensions 2>/dev/null | grep -q "opencode-wzrd"; then
            echo -e "${GREEN}✅ Extension found, activating...${NC}"
            opencode --extension opencode-wzrd "$@"
        else
            echo -e "${YELLOW}⚠️  Extension not installed. Installing...${NC}"
            npm install -g opencode-wzrd
            echo -e "${GREEN}✅ Extension installed. Launching...${NC}"
            opencode --extension opencode-wzrd "$@"
        fi
    else
        echo -e "${RED}❌ OpenCode not found.${NC}"
        echo ""
        echo "Install OpenCode from: https://opencode.dev"
        echo "Or use terminal mode: wzrd chat \"Your message\""
        exit 1
    fi
}

# Install OpenCode and extension
install_opencode() {
    echo -e "${BLUE}📦 Installing OpenCode + WZRD.dev extension...${NC}"
    
    # Check Node.js
    if ! command -v node &> /dev/null; then
        echo -e "${RED}❌ Node.js required. Install from: https://nodejs.org${NC}"
        exit 1
    fi
    
    # Install OpenCode if available via npm
    if npm list -g opencode 2>/dev/null | grep -q "opencode"; then
        echo -e "${GREEN}✅ OpenCode already installed${NC}"
    else
        echo -e "${YELLOW}📦 Installing OpenCode...${NC}"
        echo -e "${YELLOW}Note: OpenCode may need to be installed from https://opencode.dev${NC}"
        echo ""
        echo "Please install OpenCode manually from:"
        echo "  https://opencode.dev/download"
        echo ""
        read -p "Press Enter after installing OpenCode..."
    fi
    
    # Install extension
    echo -e "${YELLOW}📦 Installing WZRD.dev extension...${NC}"
    npm install -g opencode-wzrd
    
    echo -e "${GREEN}✅ Installation complete!${NC}"
    echo ""
    echo "Launch with: wzrd --launch-opencode"
    echo "Or use terminal: wzrd chat \"Hello Remi\""
}

# Terminal mode (default)
terminal_mode() {
    # Use the wzrd CLI from our package
    if command -v node &> /dev/null && [ -f "$(dirname "$0")/dist/cli.js" ]; then
        node "$(dirname "$0")/dist/cli.js" "$@"
    else
        echo -e "${YELLOW}📦 WZRD CLI not found locally, using global...${NC}"
        if command -v wzrd &> /dev/null; then
            wzrd "$@"
        else
            echo -e "${RED}❌ WZRD CLI not installed.${NC}"
            echo "Install with: npm install -g opencode-wzrd"
            exit 1
        fi
    fi
}

# Main execution
main() {
    print_header
    
    # Parse arguments
    if [ $# -eq 0 ]; then
        # Default: interactive choice
        echo "How would you like to use WZRD.dev?"
        echo ""
        echo "1) Launch OpenCode with extension (recommended)"
        echo "2) Use terminal mode"
        echo "3) Install OpenCode + extension"
        echo ""
        read -p "Select [1-3]: " choice
        
        case $choice in
            1) launch_opencode ;;
            2) terminal_mode ;;
            3) install_opencode ;;
            *) echo "Invalid choice"; show_help ;;
        esac
        exit 0
    fi
    
    case "$1" in
        --launch-opencode|-l)
            shift
            launch_opencode "$@"
            ;;
        --terminal|-t)
            shift
            terminal_mode "$@"
            ;;
        --install|-i)
            install_opencode
            ;;
        --version|-v)
            echo "WZRD.dev OpenCode Launcher v0.1.1"
            echo "Package: opencode-wzrd"
            echo "GitHub: https://github.com/mdthewzrd/opencodewzrd"
            ;;
        --help|-h)
            show_help
            ;;
        chat|modes|skills|setup)
            terminal_mode "$@"
            ;;
        *)
            # Try as direct command
            terminal_mode "$@"
            ;;
    esac
}

# Run main function
main "$@"